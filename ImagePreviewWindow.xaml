<Window x:Class="CFRezManager.ImagePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Preview"
        Width="900"
        Height="700"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#111827"
        MinWidth="320"
        MinHeight="240">
    <DockPanel x:Name="PreviewRoot"
               Background="#111827">
        <Border x:Name="PreviewInfoBar"
                DockPanel.Dock="Top"
                Background="#1F2937"
                BorderBrush="#374151"
                BorderThickness="0,0,0,1"
                Padding="12,7"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="PreviewInfoText"
                           Foreground="#E5E7EB"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,12,0"/>
                <Button x:Name="PlayPauseButton"
                        Grid.Column="1"
                        Width="72"
                        Height="26"
                        Margin="0,0,8,0"
                        Content="Pause"
                        Click="PlayPauseButton_Click"
                        Visibility="Collapsed"/>
                <ComboBox x:Name="FrameSelector"
                          Grid.Column="2"
                          Width="240"
                          Height="26"
                          Margin="0,0,8,0"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="FrameSelector_SelectionChanged"
                          Visibility="Collapsed"/>
                <Button x:Name="PreviousImageButton"
                        Grid.Column="3"
                        Width="72"
                        Height="26"
                        Margin="0,0,8,0"
                        Content="Prev"
                        Click="PreviousImageButton_Click"
                        Visibility="Collapsed"/>
                <Button x:Name="NextImageButton"
                        Grid.Column="4"
                        Width="72"
                        Height="26"
                        Margin="0,0,8,0"
                        Content="Next"
                        Click="NextImageButton_Click"
                        Visibility="Collapsed"/>
            </Grid>
        </Border>

        <ScrollViewer x:Name="PreviewScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Padding="12"
                      Background="#111827">
            <Border Background="#0B1120"
                    BorderBrush="#374151"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                <Image x:Name="PreviewImage"
                       Stretch="Fill"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       SnapsToDevicePixels="True"/>
            </Border>
        </ScrollViewer>
    </DockPanel>
</Window>
