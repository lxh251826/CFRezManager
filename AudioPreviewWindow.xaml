<Window x:Class="CFRezManager.AudioPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Audio Preview"
        Width="710"
        Height="260"
        MinWidth="680"
        MinHeight="246"
        ResizeMode="CanResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#111111"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171717"/>
        <SolidColorBrush x:Key="PanelDarkBrush" Color="#111111"/>
        <SolidColorBrush x:Key="PanelEdgeBrush" Color="#050505"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8D8D8D"/>
        <SolidColorBrush x:Key="BrightTextBrush" Color="#F4F7FB"/>

        <Style x:Key="ChromeButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="#BDBDBD"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#303030"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransportButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="Background" Value="#1B1B1B"/>
            <Setter Property="BorderBrush" Value="#050505"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#242424"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2E2E2E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniIconButtonStyle" BasedOn="{StaticResource TransportButtonStyle}" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Background" Value="#1B1B1B"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="ThinPositionSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Height="18" VerticalAlignment="Center">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="3" Background="#E7E7E7"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="3" Background="#5A5A5A"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="13" Height="13">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Ellipse Fill="#F2F2F2" Stroke="#BFBFBF" StrokeThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinVolumeSliderStyle" BasedOn="{StaticResource ThinPositionSliderStyle}" TargetType="{x:Type Slider}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Height="18" VerticalAlignment="Center">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="3" Background="#E4D300"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="3" Background="#6A6A6A"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12" Height="12">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Ellipse Fill="#F2F2F2" Stroke="#AFAFAF" StrokeThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrackScrollBarLineButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="#151515"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F1F1F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#252525"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrackScrollBarPageButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrackScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="Root"
                                Margin="3,2"
                                CornerRadius="3"
                                Background="#3B4650"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#4A5863"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#5E7180"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="15"/>
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="VerticalRoot"
                              Width="{TemplateBinding Width}"
                              Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="15"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="15"/>
                            </Grid.RowDefinitions>

                            <RepeatButton Command="{x:Static ScrollBar.LineUpCommand}"
                                          Style="{StaticResource TrackScrollBarLineButtonStyle}">
                                <Path Width="7"
                                      Height="5"
                                      Stretch="Uniform"
                                      Fill="#6E7D88"
                                      Data="M 0 5 L 3.5 0 L 7 5 Z"/>
                            </RepeatButton>
                            <Track x:Name="PART_Track"
                                   Grid.Row="1"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Style="{StaticResource TrackScrollBarPageButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource TrackScrollBarThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Style="{StaticResource TrackScrollBarPageButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                            <RepeatButton Grid.Row="2"
                                          Command="{x:Static ScrollBar.LineDownCommand}"
                                          Style="{StaticResource TrackScrollBarLineButtonStyle}">
                                <Path Width="7"
                                      Height="5"
                                      Stretch="Uniform"
                                      Fill="#6E7D88"
                                      Data="M 0 0 L 7 0 L 3.5 5 Z"/>
                            </RepeatButton>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="VerticalRoot" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrackListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D6D6D6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                Padding="8,6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#222222"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#263A4A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.56"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#383838"
            BorderThickness="1"
            Background="{StaticResource PanelDarkBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="TrackListColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <Grid x:Name="PlayerPanel"
                  Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="31"/>
                <RowDefinition Height="62"/>
            </Grid.RowDefinitions>

            <Border x:Name="PreviewInfoBar"
                    Grid.Row="0"
                    Background="#202020"
                    BorderBrush="#050505"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="108"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="58"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Player"
                               Foreground="#A7A7A7"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="14,0,0,1"/>
                    <Border Grid.Column="1"
                            Margin="0,8"
                            Background="#0A0A0A"/>
                    <TextBlock x:Name="FormatBadgeText"
                               Grid.Column="2"
                               Text="AUDIO"
                               Foreground="#A0A0A0"
                               FontSize="13"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                    <Border Grid.Column="3"
                            Margin="0,8"
                            Background="#0A0A0A"/>
                    <TextBlock x:Name="FileNameText"
                               Grid.Column="4"
                               Foreground="#FFFFFF"
                               FontSize="14"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Margin="12,0,12,1"/>

                    <StackPanel Grid.Column="5"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource ChromeButtonStyle}"
                                Click="MinimizeButton_Click">
                            <Path Width="12" Height="12" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.8"
                                  Data="M 1 10 L 11 10"/>
                        </Button>
                        <Button Style="{StaticResource ChromeButtonStyle}"
                                Click="MaximizeRestoreButton_Click">
                            <Path Width="11" Height="11" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.5"
                                  Data="M 1 1 L 10 1 L 10 10 L 1 10 Z"/>
                        </Button>
                        <Button Style="{StaticResource ChromeButtonStyle}"
                                Click="CloseButton_Click">
                            <Path Width="12" Height="12" Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Square"
                                  StrokeEndLineCap="Square"
                                  Data="M 1 1 L 11 11 M 11 1 L 1 11"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="22,10,16,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="134"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="216"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="ElapsedLargeText"
                               Text="00:00"
                               Foreground="#F7F7F7"
                               FontSize="44"
                               FontWeight="Bold"
                               LineHeight="46"/>
                    <TextBlock x:Name="DurationText"
                               Text="00:00"
                               Foreground="#898989"
                               FontSize="19"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,4,22,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="8,0,16,0">
                    <TextBlock x:Name="NowPlayingText"
                               Foreground="#FFFFFF"
                               FontSize="16"
                               FontWeight="SemiBold"
                               LineHeight="20"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="PreviewInfoText"
                               Foreground="#8B8B8B"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,9,0,0"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Background="#111111"
                        BorderThickness="0"
                        Padding="0"
                        VerticalAlignment="Center">
                    <Image x:Name="WaveformImage"
                           Height="58"
                           Stretch="Fill"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           SizeChanged="WaveformCanvas_SizeChanged"/>
                </Border>
            </Grid>

            <Grid Grid.Row="2"
                  Background="#101010">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="122"/>
                </Grid.ColumnDefinitions>

                <Ellipse Width="11"
                         Height="11"
                         Fill="#F2F2F2"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"/>
                <Slider x:Name="PositionSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="1"
                        VerticalAlignment="Center"
                        Style="{StaticResource ThinPositionSliderStyle}"
                        PreviewMouseLeftButtonDown="PositionSlider_PreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="PositionSlider_PreviewMouseLeftButtonUp"
                        ValueChanged="PositionSlider_ValueChanged"/>
                <Path Grid.Column="2"
                      Width="15"
                      Height="15"
                      Stretch="Uniform"
                      Fill="#8E8E8E"
                      VerticalAlignment="Center"
                      Data="M 1 6 L 5 6 L 10 2 L 10 16 L 5 12 L 1 12 Z M 13 6 C 15 8 15 10 13 12"/>
                <Slider x:Name="VolumeSlider"
                        Grid.Column="3"
                        Width="112"
                        Minimum="0"
                        Maximum="1"
                        Value="0.8"
                        VerticalAlignment="Center"
                        Style="{StaticResource ThinVolumeSliderStyle}"
                        ValueChanged="VolumeSlider_ValueChanged"/>
            </Grid>

            <Grid Grid.Row="3"
                  Background="#1A1A1A">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PlayButton"
                        Style="{StaticResource TransportButtonStyle}"
                        Click="PlayButton_Click">
                    <Path x:Name="PlayIcon"
                          Width="20" Height="20" Stretch="Uniform"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Data="M 3 1 L 18 10 L 3 19 Z"/>
                </Button>
                <Button x:Name="StopButton"
                        Grid.Column="1"
                        Style="{StaticResource TransportButtonStyle}"
                        Click="StopButton_Click">
                    <Path Width="15" Height="15" Stretch="Uniform"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Data="M 2 2 L 14 2 L 14 14 L 2 14 Z"/>
                </Button>
                <Button x:Name="PreviousAudioButton"
                        Grid.Column="2"
                        Style="{StaticResource TransportButtonStyle}"
                        Click="PreviousAudioButton_Click">
                    <Path Width="21" Height="17" Stretch="Uniform"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Data="M 17 1 L 7 8.5 L 17 16 Z M 7 1 L 1 8.5 L 7 16 Z"/>
                </Button>
                <Button x:Name="NextAudioButton"
                        Grid.Column="3"
                        Style="{StaticResource TransportButtonStyle}"
                        Click="NextAudioButton_Click">
                    <Path Width="21" Height="17" Stretch="Uniform"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Data="M 1 1 L 11 8.5 L 1 16 Z M 11 1 L 17 8.5 L 11 16 Z"/>
                </Button>

                <TextBlock x:Name="TimeText"
                           Grid.Column="4"
                           Text="00:00:00 / 00:00:00"
                           Foreground="#F8FAFC"
                           FontSize="15"
                           VerticalAlignment="Center"
                           Margin="22,0,0,0"/>
                <Button x:Name="RepeatModeButton"
                        Grid.Column="5"
                        Style="{StaticResource TransportButtonStyle}"
                        BorderThickness="1,0,0,0"
                        Click="RepeatModeButton_Click">
                    <Grid Width="24"
                          Height="22">
                        <Path x:Name="RepeatModeIcon"
                              Width="22"
                              Height="17"
                              Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Data="M 5 4 L 16 4 L 19 7 M 19 7 L 16 10 M 19 7 L 5 7 M 19 15 L 8 15 L 5 12 M 5 12 L 8 9 M 5 12 L 19 12"/>
                        <TextBlock x:Name="RepeatOneBadge"
                                   Text="1"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="1,0,0,1"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Button>
            </Grid>

            <MediaElement x:Name="AudioPlayer"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Stop"
                          Visibility="Collapsed"
                          MediaOpened="AudioPlayer_MediaOpened"
                          MediaEnded="AudioPlayer_MediaEnded"
                          MediaFailed="AudioPlayer_MediaFailed"/>
            </Grid>

            <Border x:Name="TrackListPanel"
                    Grid.Column="1"
                    Width="272"
                    Background="#151515"
                    BorderBrush="#050505"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Background="#1C1C1C">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Tracks"
                                   Foreground="#F4F7FB"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="12,0,8,0"/>
                        <StackPanel x:Name="TrackLoadingPanel"
                                   Grid.Column="1"
                                   Orientation="Horizontal"
                                   VerticalAlignment="Center"
                                   Margin="8,0,10,0"
                                   Visibility="Collapsed">
                            <Grid Width="28"
                                  Height="3"
                                  VerticalAlignment="Center"
                                  Margin="0,0,6,0"
                                  Background="#2A2A2A"
                                  ClipToBounds="True">
                                <Rectangle Width="10"
                                           Height="3"
                                           HorizontalAlignment="Left"
                                           Fill="#42B8FF"
                                           RadiusX="1.5"
                                           RadiusY="1.5">
                                    <Rectangle.RenderTransform>
                                        <TranslateTransform x:Name="TrackLoadingSweep"/>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                                <Grid.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="TrackLoadingSweep"
                                                                 Storyboard.TargetProperty="X"
                                                                 From="-10"
                                                                 To="28"
                                                                 Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Grid.Triggers>
                            </Grid>
                            <TextBlock Text="加载中"
                                       Foreground="#8D8D8D"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TrackCountText"
                                   Grid.Column="2"
                                   Foreground="#8D8D8D"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="8,0,12,0"/>
                    </Grid>

                    <ListBox x:Name="TrackListBox"
                             Grid.Row="1"
                             Background="#151515"
                             BorderThickness="0"
                             Foreground="#D6D6D6"
                             ItemContainerStyle="{StaticResource TrackListBoxItemStyle}"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             SelectionChanged="TrackListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Number}"
                                               Foreground="#7F8C99"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
