<Window x:Class="CFRezManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CFRezManager"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="CF Rez Manager" Height="760" Width="1180" MinHeight="560" MinWidth="900"
        PreviewMouseDown="Window_PreviewMouseDown">
    <Window.Resources>
        <sys:Double x:Key="TileItemWidthValue">136</sys:Double>
        <sys:Double x:Key="TileItemHeightValue">128</sys:Double>
        <sys:Double x:Key="TileCellWidthValue">148</sys:Double>
        <sys:Double x:Key="TileCellHeightValue">140</sys:Double>
        <sys:Double x:Key="TileIconSizeValue">61</sys:Double>
        <GridLength x:Key="TileIconRowHeightValue">71</GridLength>
        <sys:Double x:Key="TileFileIconWidthValue">50</sys:Double>
        <sys:Double x:Key="TileFilePageWidthValue">42</sys:Double>
        <sys:Double x:Key="TileFilePageHeightValue">54</sys:Double>
        <sys:Double x:Key="TileNameMaxHeightValue">44</sys:Double>

        <Style x:Key="BreadcrumbButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <ControlTemplate x:Key="ExplorerListBoxItemTemplate" TargetType="{x:Type ListBoxItem}">
            <Border x:Name="ItemBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="#F1F5F9"/>
                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#D7DCE2"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="#E8F1FE"/>
                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#7AA7E8"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter TargetName="ItemBorder" Property="Background" Value="#DCEBFD"/>
                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#5B8FD8"/>
                </MultiTrigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#4F83D1"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="ExplorerTileItemStyle" TargetType="ListBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="{DynamicResource TileItemWidthValue}"/>
            <Setter Property="Height" Value="{DynamicResource TileItemHeightValue}"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template" Value="{StaticResource ExplorerListBoxItemTemplate}"/>
        </Style>

        <Style x:Key="ExplorerListItemStyle" TargetType="ListBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template" Value="{StaticResource ExplorerListBoxItemTemplate}"/>
        </Style>

        <ItemsPanelTemplate x:Key="ExplorerTilePanelTemplate">
            <local:VirtualizingWrapPanel ItemWidth="{DynamicResource TileCellWidthValue}"
                                         ItemHeight="{DynamicResource TileCellHeightValue}"
                                         CacheRows="2"/>
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="ExplorerListPanelTemplate">
            <VirtualizingStackPanel/>
        </ItemsPanelTemplate>

        <DataTemplate x:Key="ExplorerIconTemplate">
            <Grid ToolTip="{Binding InfoToolTip}"
                  Loaded="ExplorerItemTemplate_Loaded"
                  DataContextChanged="ExplorerItemTemplate_DataContextChanged">
                <Grid.RowDefinitions>
                    <RowDefinition Height="{DynamicResource TileIconRowHeightValue}"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Image x:Name="FolderIcon"
                       Source="{Binding IconSource}"
                       Width="{DynamicResource TileIconSizeValue}"
                       Height="{DynamicResource TileIconSizeValue}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                <Grid x:Name="FileIcon"
                      Width="{DynamicResource TileFileIconWidthValue}"
                      Height="{DynamicResource TileIconSizeValue}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="Collapsed">
                    <Border Width="{DynamicResource TileFilePageWidthValue}"
                            Height="{DynamicResource TileFilePageHeightValue}"
                            Background="#FFFFFF"
                            BorderBrush="#BFC6D1"
                            BorderThickness="1"
                            CornerRadius="2">
                        <TextBlock Text="FILE"
                                   Foreground="#6B7280"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Border Width="14"
                            Height="14"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,4,6,0"
                            Background="#E5E7EB"
                            BorderBrush="#BFC6D1"
                            BorderThickness="0,0,1,1"/>
                </Grid>

                <Border x:Name="ThumbnailFrame"
                        Width="{DynamicResource TileIconSizeValue}"
                        Height="{DynamicResource TileIconSizeValue}"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                    <Grid ClipToBounds="True">
                        <Image Source="{Binding ThumbnailSource}"
                               Stretch="Uniform"/>
                        <Border x:Name="ThumbnailBadge"
                                Background="#D9111827"
                                CornerRadius="2"
                                Padding="3,1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Visibility="Collapsed">
                            <TextBlock Text="{Binding ThumbnailBadgeText}"
                                       Foreground="#FFFFFF"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       LineHeight="10"/>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="1"
                           Text="{Binding Name}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           MaxHeight="{DynamicResource TileNameMaxHeightValue}"
                           LineHeight="16"
                           FontSize="12"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsContainer}" Value="False">
                    <Setter TargetName="FolderIcon" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="FileIcon" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasThumbnail}" Value="True">
                    <Setter TargetName="FileIcon" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ThumbnailFrame" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasThumbnailBadge}" Value="True">
                    <Setter TargetName="ThumbnailBadge" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="ExplorerListTemplate">
            <Grid ToolTip="{Binding InfoToolTip}"
                  Loaded="ExplorerItemTemplate_Loaded"
                  DataContextChanged="ExplorerItemTemplate_DataContextChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="ListFolderIcon"
                       Source="{Binding IconSource}"
                       Width="22"
                       Height="22"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                <Grid x:Name="ListFileIcon"
                      Width="20"
                      Height="24"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="Collapsed">
                    <Border Background="#FFFFFF"
                            BorderBrush="#BFC6D1"
                            BorderThickness="1"
                            CornerRadius="1"/>
                    <TextBlock Text="F"
                               Foreground="#6B7280"
                               FontSize="10"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <Border x:Name="ListThumbnailFrame"
                        Width="28"
                        Height="28"
                        Background="#FFFFFF"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                    <Grid ClipToBounds="True">
                        <Image Source="{Binding ThumbnailSource}"
                               Stretch="Uniform"/>
                        <Border x:Name="ListThumbnailBadge"
                                Background="#D9111827"
                                CornerRadius="1"
                                Padding="1,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Visibility="Collapsed">
                            <TextBlock Text="{Binding CompactThumbnailBadgeText}"
                                       Foreground="#FFFFFF"
                                       FontSize="7"
                                       FontWeight="SemiBold"
                                       LineHeight="8"/>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock Grid.Column="1"
                           Text="{Binding Name}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           Margin="6,0,10,0"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding LocationText}"
                           Foreground="#6B7280"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <TextBlock Grid.Column="3"
                           Text="{Binding SizeText}"
                           Foreground="#4B5563"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           MinWidth="86"
                           TextAlignment="Right"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsContainer}" Value="False">
                    <Setter TargetName="ListFolderIcon" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ListFileIcon" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasThumbnail}" Value="True">
                    <Setter TargetName="ListFileIcon" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ListThumbnailFrame" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasThumbnailBadge}" Value="True">
                    <Setter TargetName="ListThumbnailBadge" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button x:Name="BrowseFolderButton"
                        Content="选择文件夹..."
                        Click="BrowseFolderButton_Click"
                        Padding="14,7"
                        Margin="0,0,8,0"/>
                <Button x:Name="ExtractAllButton"
                        Content="全部导出..."
                        Click="ExtractAllButton_Click"
                        IsEnabled="False"
                        Padding="14,7"
                        Margin="0,0,8,0"/>
                <Button x:Name="PackFolderButton"
                        Content="打包文件夹..."
                        Click="PackFolderButton_Click"
                        Padding="14,7"
                        Margin="0,0,8,0"/>
                <ComboBox x:Name="LanguageComboBox"
                          Width="116"
                          Padding="8,6"
                          VerticalContentAlignment="Center"
                          SelectionChanged="LanguageComboBox_SelectionChanged">
                    <ComboBoxItem Content="中文" Tag="zh"/>
                    <ComboBoxItem Content="English" Tag="en"/>
                </ComboBox>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock x:Name="SearchLabelText"
                           Text="Search:"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBox x:Name="SearchTextBox"
                         Width="280"
                         Padding="8,5"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchTextBox_TextChanged"/>
                <Button x:Name="ClearSearchButton"
                        Content="X"
                        Click="ClearSearchButton_Click"
                        IsEnabled="False"
                        Padding="10,5"
                        Margin="6,0,0,0"/>
            </StackPanel>

            <TextBlock x:Name="HeaderText"
                       Text="选择一个文件夹扫描 REZ 资源包"
                       Visibility="Collapsed"
                       VerticalAlignment="Center"
                       FontSize="17"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <Border Grid.Row="1"
                BorderBrush="#D7DCE2"
                BorderThickness="1"
                Background="#F8FAFC"
                Margin="0,0,0,10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="BreadcrumbPanel"
                            Orientation="Horizontal"
                            Margin="6,4"/>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" BorderBrush="#D7DCE2" BorderThickness="1">
            <DockPanel>
                <TextBlock x:Name="ContentsHeaderText"
                           DockPanel.Dock="Top"
                           Text="内容"
                           FontWeight="SemiBold"
                           Padding="10,8"
                           Background="#F5F7FA"/>

                <Grid>
                    <ListBox x:Name="ContentsList"
                             MouseDoubleClick="ContentsList_MouseDoubleClick"
                             PreviewMouseLeftButtonDown="ContentsList_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="ContentsList_PreviewMouseMove"
                             PreviewMouseLeftButtonUp="ContentsList_PreviewMouseLeftButtonUp"
                             PreviewMouseRightButtonDown="ContentsList_PreviewMouseRightButtonDown"
                             LostMouseCapture="ContentsList_LostMouseCapture"
                             BorderThickness="0"
                             ItemTemplate="{StaticResource ExplorerIconTemplate}"
                             ItemContainerStyle="{StaticResource ExplorerTileItemStyle}"
                             SelectionMode="Extended"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.IsDeferredScrollingEnabled="False"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ItemsPanel="{StaticResource ExplorerTilePanelTemplate}">
                        <ListBox.ContextMenu>
                            <ContextMenu Opened="ContentsContextMenu_Opened">
                                <MenuItem x:Name="OpenPreviewMenuItem"
                                          Header="打开预览..."
                                          Click="OpenPreviewMenuItem_Click"/>
                                <MenuItem x:Name="DecodeBankMenuItem"
                                          Header="Decode BANK..."
                                          Click="DecodeBankMenuItem_Click"/>
                                <MenuItem x:Name="ExportObjMenuItem"
                                          Header="Export OBJ..."
                                          Click="ExportObjMenuItem_Click"/>
                                <Separator x:Name="PreviewMenuSeparator"/>
                                <MenuItem x:Name="LocateFileMenuItem"
                                          Header="定位到文件"
                                          Click="LocateFileMenuItem_Click"/>
                                <MenuItem x:Name="CopyNameMenuItem"
                                          Header="Copy Name"
                                          Click="CopyNameMenuItem_Click"/>
                                <MenuItem x:Name="ExtractSelectedMenuItem"
                                          Header="导出选中项..."
                                          Click="ExtractSelectedMenuItem_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>

                    <Canvas x:Name="SelectionOverlay"
                            IsHitTestVisible="False"
                            ClipToBounds="True">
                        <Border x:Name="SelectionBox"
                                Background="#334F83D1"
                                BorderBrush="#4F83D1"
                                BorderThickness="1"
                                Visibility="Collapsed"/>
                    </Canvas>

                    <StackPanel x:Name="EmptyStatePanel"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Image x:Name="EmptyStateImage"
                               Width="112"
                               Height="112"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"/>
                        <TextBlock Text="&#x7A7A;&#x76EE;&#x5F55;"
                                   x:Name="EmptyStateText"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"
                                   FontSize="15"
                                   Foreground="#6B7280"/>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,8,0,0" LastChildFill="True">
            <StackPanel x:Name="ViewSizePanel"
                        DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                <TextBlock x:Name="ViewSizeLabelText"
                           Text="Size"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <Slider x:Name="ViewSizeSlider"
                        Width="150"
                        Minimum="0"
                        Maximum="100"
                        Value="72"
                        SmallChange="5"
                        LargeChange="15"
                        TickFrequency="25"
                        IsSnapToTickEnabled="False"
                        VerticalAlignment="Center"
                        ValueChanged="ViewSizeSlider_ValueChanged"/>
            </StackPanel>
            <ProgressBar x:Name="WorkProgress"
                         DockPanel.Dock="Right"
                         Width="220"
                         Height="8"
                         Minimum="0"
                         Maximum="100"
                         Visibility="Collapsed"/>
            <TextBlock x:Name="StatusText"
                       Text="就绪"
                       Foreground="#4B5563"
                       VerticalAlignment="Center"/>
        </DockPanel>
    </Grid>
</Window>
